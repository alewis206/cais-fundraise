# Copy to .env and fill in. Required keys are noted per phase.

# --- Phase 1 (REQUIRED) ---
ANTHROPIC_API_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./secrets/google-sa.json

# Database
DB_PATH=./data/prospects.db

# Classifier models
CLASSIFIER_DEFAULT_MODEL=claude-sonnet-4-6
CLASSIFIER_TIER1_MODEL=claude-opus-4-7

# Cost guardrail (USD). classify --all prompts for confirmation above this.
COST_CEILING_USD=50

# --- Phase 2 (REQUIRED for email enrichment) ---
APOLLO_API_KEY=
HUNTER_API_KEY=

ENRICHMENT_CACHE_DAYS=30

# --- Phase 3 (HIGH VALUE) ---
CRUNCHBASE_API_KEY=

# --- Phase 3 (OPTIONAL) ---
TWITTER_BEARER_TOKEN=

# --- Logging ---
LOG_LEVEL=INFO
